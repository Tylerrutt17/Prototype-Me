{
  "name": "@prototype-me/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "docker compose up -d && tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "aws-jwt-verify": "^4.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.39.0",
    "fastify": "^5.2.0",
    "formidable": "^3.5.4",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "postgres": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/formidable": "^3.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
